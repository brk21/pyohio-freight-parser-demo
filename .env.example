# Copy to .env and tweak if you like. Every value has a sane default in code,
# so the demo runs with no .env at all.

# --- Model registry overrides -------------------------------------------------
# The registry lives in packages/finetune/models.toml. You can override any base
# model id here without editing the repo (handy for air-gapped mirrors).
# FREIGHT_MODEL_OLDER=Qwen/Qwen2-0.5B-Instruct
# FREIGHT_MODEL_NEWER=Qwen/Qwen2.5-0.5B-Instruct
# FREIGHT_MODEL_LIGHTWEIGHT=HuggingFaceTB/SmolLM2-360M-Instruct

# --- Hugging Face cache / offline -------------------------------------------
# Where downloaded weights are cached. Point this at a repo-local dir if you
# want a fully self-contained checkout after the first download.
# HF_HOME=./.hf_cache

# After the first successful download you can go fully offline:
# HF_HUB_OFFLINE=1
# TRANSFORMERS_OFFLINE=1

# --- Serving ------------------------------------------------------------------
# Default model served by the playground when no ?model= is requested.
# FREIGHT_DEFAULT_MODEL=newer
# FREIGHT_ADAPTERS_DIR=./data/adapters
